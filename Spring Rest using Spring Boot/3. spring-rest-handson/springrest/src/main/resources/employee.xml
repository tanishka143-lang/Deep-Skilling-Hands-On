<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
 http://www.springframework.org/schema/beans
 http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Departments -->
    <bean id="dept1" class="com.cognizant.springrest.model.Department">
        <constructor-arg value="1"/>
        <constructor-arg value="HR"/>
    </bean>

    <bean id="dept2" class="com.cognizant.springrest.model.Department">
        <constructor-arg value="2"/>
        <constructor-arg value="IT"/>
    </bean>

    <!-- Employee List -->
    <bean id="employeeList" class="java.util.ArrayList">
        <constructor-arg>
            <list>

                <bean class="com.cognizant.springrest.model.Employee">
                    <constructor-arg value="101"/>
                    <constructor-arg value="Tanishka"/>
                    <constructor-arg value="50000"/>
                    <constructor-arg ref="dept1"/>
                    <constructor-arg>
                        <list>
                            <value>Java</value>
                            <value>Spring</value>
                        </list>
                    </constructor-arg>
                </bean>

                <bean class="com.cognizant.springrest.model.Employee">
                    <constructor-arg value="102"/>
                    <constructor-arg value="Rahul"/>
                    <constructor-arg value="60000"/>
                    <constructor-arg ref="dept2"/>
                    <constructor-arg>
                        <list>
                            <value>Angular</value>
                        </list>
                    </constructor-arg>
                </bean>

            </list>
        </constructor-arg>
    </bean>

</beans>